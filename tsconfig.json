{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "node",
		"allowJs": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strict": true,
		"esModuleInterop": true,
		"importHelpers": true,
		"isolatedModules": true,
		"lib": [
			"ES2020",
			"DOM",
			"DOM.Iterable"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
